#!/usr/bin/env bash
set -u

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

fail=0

echo "notes-skill status"
echo

echo "repo: $ROOT"
echo "version: $(cat VERSION 2>/dev/null || echo unknown)"
echo

echo "required files:"
for path in AGENTS.md CONTEXT.md REFERENCES.md README.md SKILL.md RELEASE.md scripts/notes-runner scripts/release-check.sh; do
  if [[ -e "$path" ]]; then
    echo "  ok   $path"
  else
    echo "  miss $path"
    fail=1
  fi
done

echo
echo "workspace folders:"
for path in drafts final references outputs tests scripts/notes_runner_lib; do
  if [[ -d "$path" ]]; then
    echo "  ok   $path/"
  else
    echo "  miss $path/"
    fail=1
  fi
done

echo
echo "git status:"
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git status --short
else
  echo "  not a git repo"
  fail=1
fi

echo
echo "doctor:"
if python3 scripts/notes-runner doctor --json; then
  :
else
  fail=1
fi

exit "$fail"
