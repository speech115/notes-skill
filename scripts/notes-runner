DEFAULT_TELEGRAM_CAPTION_TEMPLATE = ""
DEFAULT_TELEGRAM_CHAT = "-1003850136767"
MARKDOWN_H1_RE = re.compile(r"^\s*#\s+(.+?)\s*$")
TITLE_TIMESTAMP_PREFIX_RE = re.compile(r"^(?:\*?\d{1,2}:\d{2}(?::\d{2})?\*?\s+)+", re.IGNORECASE)
TITLE_SPEAKER_PREFIX_RE = re.compile(r"^(?:\*\*)?speaker\s+\d+(?:\*\*)?\s*:?\s*", re.IGNORECASE)
TITLE_GENERIC_STEM_RE = re.compile(r"^(?:transcript|notes|summary|audio|video|recording|source|meeting|lecture)$", re.IGNORECASE)
