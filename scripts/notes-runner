        load_json_if_exists=load_json_if_exists,
        read_summary_points=read_summary_points,
        read_text_file=read_text_file,
        write_text=write_text,
    )


def merge_manifest_parts(work_dir: Path) -> Path | None:
    return merge_manifest_parts_impl(work_dir, write_text=write_text)


def cmd_ensure_appendix(args: argparse.Namespace) -> int:
    return run_ensure_appendix_command(
        args,
        deps=AppendixCommandDependencies(
            ensure_dir=ensure_dir,
            merge_manifest_parts=merge_manifest_parts,
            build_deterministic_appendix=build_deterministic_appendix,
            stdout=sys.stdout,
        ),
    )


def compute_final_quality_checks(work_dir: Path, output_md: Path) -> dict:
    return compute_final_quality_checks_impl(
        work_dir,
        output_md,
        update_prepare_state_fields=update_prepare_state_fields,
    )


def contract_errors_for_quality(prepare_payload: dict, quality_payload: dict) -> list[str]:
    return contract_errors_for_quality_impl(prepare_payload, quality_payload)


def cmd_assemble(args: argparse.Namespace) -> int:
    shell_deps = AssembleShellDependencies(
        assemble_script=ASSEMBLE_SCRIPT,
        ensure_dir=ensure_dir,
        merge_manifest_parts=merge_manifest_parts,
        build_deterministic_appendix=build_deterministic_appendix,
        start_bundle_run=start_bundle_run,
        subprocess_run=subprocess.run,
        handle_assemble_shell_failure=handle_assemble_shell_failure,
        update_prepare_state_fields=update_prepare_state_fields,
        write_stage_sentinel=write_stage_sentinel,
        append_trace_event=append_trace_event,
        record_bundle_stage_metric=record_bundle_stage_metric,
        finish_bundle_run=finish_bundle_run,
        ms_since=ms_since,
        stderr_sink=sys.stderr,
    )
    shell_context = prepare_assemble_shell_context(args, deps=shell_deps)
    shell_result = run_assemble_shell(args, context=shell_context, deps=shell_deps)
    if isinstance(shell_result, int):
        return shell_result
    work_dir = shell_context.work_dir
    output_md = shell_context.output_md
    output_html = shell_context.output_html
    bundle_dir = shell_context.bundle_dir
    run_context = shell_context.run_context

    success_context = build_assemble_success_context(
        work_dir,
        output_md,
        update_prepare_state_fields=update_prepare_state_fields,
        compute_final_quality_checks_fn=compute_final_quality_checks_impl,
        contract_errors_for_quality_fn=contract_errors_for_quality_impl,
    )
    contract_errors = list(success_context.get("contract_errors") or [])
    telegram_delivery = resolve_assemble_telegram_delivery(
        output_md=output_md,
        output_html=output_html,
        title=args.title,
        contract_errors=contract_errors,
        config_path=NOTES_CONFIG_PATH,
        chat_override=getattr(args, "send_to", None),
        skip_telegram=bool(getattr(args, "skip_telegram", False)),
        force_telegram_resend=bool(getattr(args, "force_telegram_resend", False)),
        resolve_digest_runner=resolve_digest_runner,
        run_command=run_command,
        env_flag_enabled=env_flag_enabled,
    )
    duration_ms = ms_since(shell_context.started_at)
    return finalize_assemble_success(
        args=args,
        work_dir=work_dir,
        bundle_dir=bundle_dir,
        output_md=output_md,
        output_html=output_html,
        duration_ms=duration_ms,
        run_context=run_context,
        success_context=success_context,
        telegram_delivery=telegram_delivery,
        deps=AssembleFinalizeDependencies(
            stage_sentinel_path=stage_sentinel_path,
            write_stage_sentinel=write_stage_sentinel,
            quality_checks_path=quality_checks_path,
            update_prepare_state_fields=update_prepare_state_fields,
            record_bundle_stage_metric=record_bundle_stage_metric,
            finish_bundle_run=finish_bundle_run,
            iso_now=iso_now,
            stdout=sys.stdout,
            stderr=sys.stderr,
        ),
    )


TEXT_EXTENSIONS = {".md", ".txt"}


def cmd_batch(args: argparse.Namespace) -> int:
    return run_batch_command(
        args,
        deps=BatchCommandDependencies(
            ensure_parent_dir=ensure_parent_dir,
            append_trace_event=append_trace_event,
            process_batch_file=process_batch_file,
            write_batch_indexes=write_batch_indexes,
            cmd_local=cmd_local,
            cmd_audio=cmd_audio,
            audio_extensions=AUDIO_EXTENSIONS,
            video_extensions=VIDEO_EXTENSIONS,
            text_extensions=TEXT_EXTENSIONS,
            write_json=write_json,
            write_text=write_text,
            stdout=sys.stdout,
            stderr=sys.stderr,
        ),
    )


def cmd_doctor(args: argparse.Namespace) -> int:
    return run_doctor_command(
        args,
        deps=DoctorCommandDependencies(
            build_doctor_checks=build_doctor_checks,
            render_doctor_report=render_doctor_report,
            platform=sys.platform,
            python_version=sys.version.split()[0],
            which=shutil.which,
            groq_api_key_present=bool(os.environ.get("GROQ_API_KEY")),
            skill_root=NOTES_SKILL_ROOT,
            config_path=NOTES_CONFIG_PATH,
            load_notes_config=load_notes_config,
            env_flag_enabled=env_flag_enabled,
            is_macos=is_macos,
            parakeet_available=parakeet_available,
            mlx_whisper_available=mlx_whisper_available,
            python_module_available=python_module_available,
            stdout=sys.stdout,
        ),
    )


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        if args.command == "batch":
            return cmd_batch(args)
        if args.command == "prepare":
            return cmd_prepare(args)
        if args.command == "status":
            return cmd_status(args)
        if args.command == "replace-speakers":
            return cmd_replace_speakers(args)
        if args.command == "build-tldr":
            return cmd_build_tldr(args)
        if args.command == "build-header":
            return cmd_build_header(args)
        if args.command == "ensure-appendix":
            return cmd_ensure_appendix(args)
        if args.command == "assemble":
            return cmd_assemble(args)
        if args.command == "youtube":
            return cmd_youtube(args)
        if args.command == "local":
            return cmd_local(args)
        if args.command == "audio":
            return cmd_audio(args)
        if args.command == "telegram":
            return cmd_telegram(args)
        if args.command == "auto":
            return cmd_auto(args)
        if args.command == "doctor":
            return cmd_doctor(args)
        parser.error(f"Unsupported command: {args.command}")
    except KeyboardInterrupt:
        print("Cancelled.", file=sys.stderr)
        return 130
    except (ValueError, FileNotFoundError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
