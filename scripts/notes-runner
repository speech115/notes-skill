        default_telegram_mcp_url=DEFAULT_TELEGRAM_MCP_URL,
    )


def ensure_file(path: Path, label: str) -> Path:
    resolved = path.expanduser().resolve()
    if not resolved.is_file():
        raise FileNotFoundError(f"{label} not found: {resolved}")
    return resolved


def ensure_dir(path: Path, label: str) -> Path:
    resolved = path.expanduser().resolve()
    if not resolved.is_dir():
        raise FileNotFoundError(f"{label} not found: {resolved}")
    return resolved


def ensure_parent_dir(path: Path) -> Path:
    resolved = path.expanduser().resolve()
    resolved.mkdir(parents=True, exist_ok=True)
    return resolved


def resolve_yt_dlp_bin() -> str:
    override = os.environ.get("NOTES_RUNNER_YTDLP_BIN")
    if override:
        return str(Path(override).expanduser())
    found = shutil.which("yt-dlp")
    if found:
        return found
    raise FileNotFoundError("yt-dlp not found. Install it or set NOTES_RUNNER_YTDLP_BIN.")


def resolve_transcribe_cli() -> Path:
    override = os.environ.get("NOTES_RUNNER_TRANSCRIBE_CLI")
    if override:
        resolved = Path(override).expanduser()
        if not resolved.is_file():
            raise FileNotFoundError(f"NOTES_RUNNER_TRANSCRIBE_CLI points to a missing file: {resolved}")
        return resolved

    bundled = NOTES_SKILL_ROOT / "scripts" / "transcribe_diarize.py"
    if bundled.is_file():
        return bundled

    raise FileNotFoundError(
        advanced_setup_message(
            "YouTube transcription fallback",
            "Starter mode only supports videos with subtitles/autosubs. To enable fallback transcription, set NOTES_RUNNER_TRANSCRIBE_CLI",
        )
    )


def resolve_digest_runner() -> Path:
    override = os.environ.get("NOTES_RUNNER_DIGEST_RUNNER")
    if override:
        resolved = Path(override).expanduser()
        if not resolved.is_file():
            raise FileNotFoundError(f"NOTES_RUNNER_DIGEST_RUNNER points to a missing file: {resolved}")
        return resolved

    found = shutil.which("digest-runner")
    if found:
        return Path(found)

    raise FileNotFoundError(
        advanced_setup_message(
            "Telegram delivery",
            "Install a compatible digest-runner and set NOTES_RUNNER_DIGEST_RUNNER if it is not in PATH",
        )
    )


def run_command(command: list[str], *, cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        command,
        cwd=cwd,
        text=True,
        capture_output=True,
        check=False,
    )


def run_checked(command: list[str], *, cwd: Path | None = None, label: str) -> subprocess.CompletedProcess[str]:
    result = run_command(command, cwd=cwd)
    if result.returncode != 0:
        stdout = result.stdout.strip()
        stderr = result.stderr.strip()
        detail = stderr or stdout or f"exit code {result.returncode}"
        raise ValueError(f"{label} failed: {detail}")
    return result


def slugify(value: str, *, max_length: int = 72) -> str:
    normalized = unicodedata.normalize("NFKD", value)
    ascii_text = normalized.encode("ascii", "ignore").decode("ascii").lower()
    slug = re.sub(r"[^a-z0-9]+", "-", ascii_text).strip("-")
    if not slug:
        slug = "notes"
    return slug[:max_length].rstrip("-") or "notes"


def extract_youtube_video_id(url: str) -> str | None:
    patterns = (
        r"(?:youtube\.com/watch\?(?:.*?&)?v=)([A-Za-z0-9_-]{11})",
        r"(?:youtu\.be/)([A-Za-z0-9_-]{11})",
        r"(?:youtube\.com/shorts/)([A-Za-z0-9_-]{11})",
        r"(?:youtube\.com/live/)([A-Za-z0-9_-]{11})",
        r"(?:youtube\.com/embed/)([A-Za-z0-9_-]{11})",
    )
    for pattern in patterns:
        match = re.search(pattern, url)
        if match:
            return match.group(1)
    return None


def extract_youtube_metadata(url: str) -> dict:
    try:
        result = run_checked(
            [resolve_yt_dlp_bin(), "--dump-single-json", "--skip-download", url],
            label="yt-dlp metadata fetch",
        )
        payload = json.loads(result.stdout)
        if not isinstance(payload, dict):
            raise ValueError("yt-dlp metadata JSON was not an object")
        return payload
    except (FileNotFoundError, ValueError, json.JSONDecodeError) as exc:
        video_id = extract_youtube_video_id(url)
        if not video_id:
            raise
        return {
            "id": video_id,
            "title": video_id,
            "webpage_url": url,
            "_metadata_warning": f"yt-dlp metadata fetch failed; using URL-derived metadata: {exc}",
        }


def bundle_dir_for(metadata: dict, output_root: Path) -> Path:
    video_id = str(metadata.get("id") or "").strip()
    title = str(metadata.get("title") or video_id or "youtube-notes").strip()
    folder_name = f"{video_id}-{slugify(title)}" if video_id else slugify(title)
    return output_root / folder_name


def local_bundle_dir_for(source_path: Path, title: str, output_root: Path) -> Path:
    path_hash = hashlib.sha1(str(source_path.expanduser().resolve()).encode("utf-8")).hexdigest()[:8]
    return output_root / f"{slugify(title)}-{path_hash}"


def note_contract_path(work_dir: Path) -> Path:
    return work_dir / NOTE_CONTRACT_FILENAME


def quality_checks_path(work_dir: Path) -> Path:
    return work_dir / QUALITY_CHECKS_FILENAME


def extract_youtube_chapters(metadata: dict) -> list[dict]:
    """Extract chapter markers from YouTube metadata.

    Checks yt-dlp's structured chapters first, then falls back to parsing
    the video description for timestamp patterns like ``0:00 Introduction``.

    Returns a list of ``{"timestamp": "MM:SS", "title": "...", "seconds": int}``.
    """

    def _ts_to_seconds(ts: str) -> int:
        parts = ts.split(":")
        if len(parts) == 3:
            return int(parts[0]) * 3600 + int(parts[1]) * 60 + int(parts[2])
        return int(parts[0]) * 60 + int(parts[1])

    def _seconds_to_ts(s: int) -> str:
        m, sec = divmod(s, 60)
        return f"{m}:{sec:02d}"

    # --- Source 1: yt-dlp structured chapters ---
    raw_chapters = metadata.get("chapters")
    if raw_chapters and isinstance(raw_chapters, list):
        result: list[dict] = []
        for ch in raw_chapters:
            start = ch.get("start_time")
            title = ch.get("title", "").strip()
            if start is not None and title:
                seconds = int(start)
                result.append({
                    "timestamp": _seconds_to_ts(seconds),
                    "title": title,
                    "seconds": seconds,
                })
        if result:
            return result

    # --- Source 2: parse description ---
    description = metadata.get("description") or ""
    chapter_re = re.compile(r"^(\d{1,2}:\d{2}(?::\d{2})?)\s+(.+)$", re.MULTILINE)
    matches = chapter_re.findall(description)
    if len(matches) >= 2:
        return [
            {
                "timestamp": ts.strip(),
                "title": title.strip(),
                "seconds": _ts_to_seconds(ts.strip()),
            }
            for ts, title in matches
        ]

    return []


def read_text_file(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="replace")


def file_looks_binary(path: Path, *, sample_size: int = 8192) -> bool:
    try:
        sample = path.read_bytes()[:sample_size]
    except OSError:
        return False
    if not sample:
        return False
    if b"\x00" in sample:
        return True

    suspicious = 0
    for byte in sample:
        if byte in {9, 10, 13}:
            continue
        if 32 <= byte <= 126:
            continue
        if byte >= 128:
            continue
        suspicious += 1
    return (suspicious / len(sample)) > 0.3


def _cleanup_title_text(value: str) -> str:
    text = html.unescape(HTML_TAG_RE.sub("", value or "")).strip()
    if not text:
        return ""
    heading_match = MARKDOWN_H1_RE.match(text)
    if heading_match:
        text = heading_match.group(1).strip()
    text = TITLE_TIMESTAMP_PREFIX_RE.sub("", text)
    text = TITLE_SPEAKER_PREFIX_RE.sub("", text)
    text = text.replace("**", "").replace("__", "").replace("`", "").replace("*", "")
    text = re.sub(r"^[>\-–—•\s:;,.]+", "", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text[:140].strip()


def _cleanup_person_hint(value: str) -> str:
    text = _cleanup_title_text(value)
    if text.startswith("@"):
        text = text[1:].strip()
    text = re.sub(r"\s+", " ", text).strip(" -|")
    return text[:80].strip()


def _humanize_path_title_hint(value: str) -> str:
    text = (value or "").strip()
    if not text:
        return ""
    text = re.sub(r"^[A-Za-z0-9_-]{11}-", "", text)
    text = re.sub(r"^\d{4}-\d{2}-\d{2}-[a-f0-9]{6,}$", "", text, flags=re.IGNORECASE)
    text = re.sub(r"-[a-f0-9]{8,}$", "", text, flags=re.IGNORECASE)
    text = text.replace("_", " ").replace("-", " ")
    text = re.sub(r"\s+", " ", text).strip(" .-_")
    if text:
        text = text[0].upper() + text[1:]
    return _cleanup_title_text(text)


def _is_informative_title(value: str) -> bool:
    text = (value or "").strip()
    if len(text) < 4:
        return False
    if TITLE_GENERIC_STEM_RE.match(text):
        return False
    if re.fullmatch(r"speaker\s+\d+", text, flags=re.IGNORECASE):
        return False
    if re.fullmatch(r"[\d\s:._-]+", text):
        return False
    return True


def _is_informative_person_hint(value: str) -> bool:
    text = (value or "").strip()
    if len(text) < 2:
        return False
    if re.fullmatch(r"speaker\s+\d+", text, flags=re.IGNORECASE):
        return False
    if re.fullmatch(r"[\d\s:._/\-]+", text):
        return False
    if text.casefold() in {"author", "creator", "uploader", "channel"}:
        return False
    return True


def build_youtube_source_hints(metadata: dict) -> dict:
    candidates: list[str] = []
    for raw in (
        metadata.get("creator"),
        metadata.get("uploader"),
        metadata.get("channel"),
        metadata.get("artist"),
    ):
        cleaned = _cleanup_person_hint(str(raw or ""))
        if cleaned and _is_informative_person_hint(cleaned):
            candidates.append(cleaned)

    deduped_candidates: list[str] = []
    seen: set[str] = set()
    for candidate in candidates:
        key = candidate.casefold()
        if key in seen:
            continue
        deduped_candidates.append(candidate)
        seen.add(key)

    uploader_handle = str(metadata.get("uploader_id") or "").strip()
    author_hint = deduped_candidates[0] if deduped_candidates else _cleanup_person_hint(uploader_handle)
    if author_hint and not _is_informative_person_hint(author_hint):
        author_hint = ""

    youtube_meta = {
        "video_id": str(metadata.get("id") or "").strip() or None,
        "channel": _cleanup_person_hint(str(metadata.get("channel") or "")) or None,
        "channel_id": str(metadata.get("channel_id") or "").strip() or None,
        "uploader": _cleanup_person_hint(str(metadata.get("uploader") or "")) or None,
        "uploader_id": uploader_handle or None,
        "creator": _cleanup_person_hint(str(metadata.get("creator") or "")) or None,
    }

    return {
        "source_kind": "youtube",
        "author_hint": author_hint or None,
        "speaker_candidates": deduped_candidates,
        "youtube": youtube_meta,
    }


def _render_source_hint_lines(source_hints: dict | None) -> list[str]:
    if not isinstance(source_hints, dict):
        return []

    author_hint = str(source_hints.get("author_hint") or "").strip()
    speaker_candidates = [
        str(item).strip()
        for item in source_hints.get("speaker_candidates", [])
        if isinstance(item, str) and str(item).strip()
    ]
    youtube_meta = source_hints.get("youtube") if isinstance(source_hints.get("youtube"), dict) else {}

    lines: list[str] = []
    if author_hint or speaker_candidates or youtube_meta:
        lines.append("=== SOURCE IDENTITY HINTS ===")
        if author_hint:
            lines.append(f"Primary author/uploader hint: {author_hint}")
        if speaker_candidates:
            lines.append(f"Speaker candidates from source metadata: {', '.join(speaker_candidates)}")
        channel = str(youtube_meta.get("channel") or "").strip()
        uploader = str(youtube_meta.get("uploader") or "").strip()
        uploader_id = str(youtube_meta.get("uploader_id") or "").strip()
        identity_bits = [item for item in [channel, uploader] if item]
        if identity_bits or uploader_id:
            identity_line = ", ".join(identity_bits)
            if uploader_id:
                identity_line = f"{identity_line} ({uploader_id})" if identity_line else uploader_id
            lines.append(f"YouTube channel/uploader metadata: {identity_line}")
        lines.append("If the transcript is a single-speaker YouTube monologue, prefer this real name over generic labels like Speaker 1 or Автор.")
    return lines


def _parse_duration_to_seconds(duration_str: str | None) -> int:
    if not duration_str:
        return 0
    parts = duration_str.split(":")
    try:
        if len(parts) == 3:
            return int(parts[0]) * 3600 + int(parts[1]) * 60 + int(parts[2])
        if len(parts) == 2:
            return int(parts[0]) * 60 + int(parts[1])
    except ValueError:
        pass
    return 0


def total_duration_seconds_for_meta(meta: list[FileMeta]) -> int:
    for item in reversed(meta):
        seconds = _parse_duration_to_seconds(item.duration_estimate)
        if seconds > 0:
            return seconds
    return 0


def duration_seconds_override_from_source_hints(source_hints: dict | None) -> int:
    if not isinstance(source_hints, dict):
        return 0
    raw = source_hints.get("duration_seconds")
    try:
        seconds = int(float(raw))
    except (TypeError, ValueError):
        return 0
    return max(0, seconds)


def format_duration_hhmmss(seconds_value: object) -> str:
    try:
        total_seconds = max(0, int(float(seconds_value)))
    except (TypeError, ValueError):
        return "unknown"
    hours, rem = divmod(total_seconds, 3600)
    minutes, seconds = divmod(rem, 60)
    return f"{hours:02d}:{minutes:02d}:{seconds:02d}" if hours > 0 else f"{minutes:02d}:{seconds:02d}"


def effective_duration_seconds_for_meta(meta: list[FileMeta], source_hints: dict | None = None) -> int:
    override = duration_seconds_override_from_source_hints(source_hints)
    return override if override > 0 else total_duration_seconds_for_meta(meta)


def effective_duration_estimate_for_meta(meta: list[FileMeta], source_hints: dict | None = None) -> str:
    override = duration_seconds_override_from_source_hints(source_hints)
    if override > 0:
        return format_duration_hhmmss(override)
    return next((item.duration_estimate for item in reversed(meta) if item.duration_estimate), "unknown")


def format_label_for_content_mode(content_mode: str) -> str:
    return format_label_for_content_mode_impl(content_mode)


def tldr_bounds_for(content_mode: str, duration_seconds: int, total_chunks: int) -> tuple[int, int]:
    return tldr_bounds_for_impl(content_mode, duration_seconds, total_chunks)


def block_contract_for(duration_seconds: int, content_mode: str) -> dict:
    return block_contract_for_impl(duration_seconds, content_mode)


def detail_density_targets_for(duration_seconds: int, content_mode: str) -> dict:
    return detail_density_targets_for_impl(duration_seconds, content_mode)


def deep_longform_targets_for(block_count: int, block_contract: dict) -> dict:
    return deep_longform_targets_for_impl(block_count, block_contract)


def min_blocks_for_chunk(
    *,
    extraction_lines: int,
    estimated_tokens: int,
    approx_duration_seconds: int,
    content_mode: str,
) -> int:
    minutes = approx_duration_seconds / 60 if approx_duration_seconds > 0 else 0
    if minutes >= 32 or extraction_lines >= 1200 or estimated_tokens >= 8000:
        return 4
    if minutes >= 18 or extraction_lines >= 650 or estimated_tokens >= 4200:
        return 3
    if minutes >= 10 or extraction_lines >= 350 or estimated_tokens >= 2200:
        return 2
    if content_mode == "monologue" and minutes <= 8 and extraction_lines < 300:
        return 1
    return 1


def _prepare_classify_content_mode(
    files: list[FileMeta],
    speaker_stage: str,
    *,
    source_hints: dict | None = None,
) -> tuple[str, str]:
    total_markers = sum(item.markers for item in files)
    total_dialogue = sum(item.dialogue_cues for item in files)
    total_dialogue_speakers = sum(item.dialogue_speakers for item in files)
    total_intro = sum(item.intro_cues for item in files)
    total_lines = sum(item.lines for item in files)
    duration_seconds = effective_duration_seconds_for_meta(files, source_hints)
    source_kind = str((source_hints or {}).get("source_kind") or "").strip()
    author_hint = _cleanup_person_hint(str((source_hints or {}).get("author_hint") or ""))
    has_author_hint = _is_informative_person_hint(author_hint)

    weak_dialogue = total_markers <= 1 and total_dialogue <= 1 and total_dialogue_speakers <= 1 and total_intro <= 1
    dense_multi_speaker = total_markers >= 3 or total_dialogue >= 8 or total_intro >= 3
    long_facilitated_session = duration_seconds >= 45 * 60 and (total_dialogue >= 5 or total_markers >= 2)
    short_facilitated_group = total_dialogue_speakers >= 3 and total_intro >= 1

    if source_kind == "youtube" and has_author_hint and weak_dialogue and (duration_seconds == 0 or duration_seconds <= 45 * 60):
        return "monologue", "youtube author hint plus weak dialog cues indicate a single-speaker monologue"
    if speaker_stage == "skip" and weak_dialogue:
        return "monologue", "speaker routing already indicates lecture-style single-speaker content"
    if dense_multi_speaker or long_facilitated_session or short_facilitated_group:
        return "workshop", "dense multi-speaker interaction suggests workshop or facilitated session"
    if speaker_stage == "required" or total_markers >= 2 or total_dialogue >= 3 or total_intro >= 2:
        return "conversation", "dialog cues suggest an interview or conversation"
    if total_lines >= 2200 and duration_seconds >= 35 * 60:
        return "workshop", "long multi-topic material defaults to workshop-style handling"
    return "conversation", "ambiguous material defaults to conversation-safe processing"


def _prepare_effective_speaker_stage(
    files: list[FileMeta],
    speaker_stage: str,
    speaker_reason: str,
    *,
    source_hints: dict | None = None,
) -> tuple[str, str, str, str]:
    content_mode, content_reason = _prepare_classify_content_mode(files, speaker_stage, source_hints=source_hints)
    author_hint = _cleanup_person_hint(str((source_hints or {}).get("author_hint") or ""))
    source_kind = str((source_hints or {}).get("source_kind") or "").strip()
    if content_mode == "monologue" and source_kind == "youtube" and _is_informative_person_hint(author_hint):
        return (
            "skip",
            f"monologue fast path: {content_reason}",
            content_mode,
            content_reason,
        )
    if content_mode == "monologue" and speaker_stage == "optional":
        return (
            "skip",
            f"monologue fast path: {content_reason}",
            content_mode,
            content_reason,
        )
    return speaker_stage, speaker_reason, content_mode, content_reason


def execution_mode_for_plan(total_chunks: int, *, content_mode: str, duration_seconds: int = 0) -> str:
    if total_chunks <= 1:
        return "single"
    if content_mode == "monologue":
        if duration_seconds and duration_seconds <= 18 * 60 and total_chunks <= 2:
            return "single"
        if total_chunks <= 4 and (duration_seconds == 0 or duration_seconds <= 35 * 60):
            return "micro-multi"
    if content_mode == "conversation" and total_chunks <= 5:
        return "micro-multi"
    if total_chunks <= 3:
        return "micro-multi"
    return "multi"


