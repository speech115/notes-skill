def _inject_source_hints_into_prescan_context(text: str, source_hints: dict | None) -> str:
    source_lines = _render_source_hint_lines(source_hints)
    if not source_lines:
        return text
    if source_lines[0] in text:
        return text
    source_block = "\n".join(source_lines).rstrip() + "\n\n"
    return source_block + text.lstrip("\n")


def infer_local_title(source_path: Path) -> str:
    stem_hint = _humanize_path_title_hint(source_path.stem)
    parent_hint = _humanize_path_title_hint(source_path.parent.name)
    generic_stem = TITLE_GENERIC_STEM_RE.match(source_path.stem or "") is not None

    for raw_line in read_text_file(source_path).splitlines():
        line = raw_line.strip()
        if not line:
            continue
        heading_match = MARKDOWN_H1_RE.match(line)
        if heading_match:
            candidate = _cleanup_title_text(heading_match.group(1))
            if _is_informative_title(candidate):
                return candidate
        candidate = _cleanup_title_text(line)
        if _is_informative_title(candidate):
            if generic_stem and _is_informative_title(parent_hint):
                return parent_hint
            return candidate

    if _is_informative_title(stem_hint):
        return stem_hint
    if _is_informative_title(parent_hint):
        return parent_hint
    return _cleanup_title_text(source_path.stem) or source_path.stem


