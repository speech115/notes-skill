SCRIPT_PATH = Path(__file__).resolve()
NOTES_SKILL_ROOT = Path(
    os.environ.get("NOTES_SKILL_ROOT", str(SCRIPT_PATH.parent.parent))
).expanduser()
PREPARE_SCRIPT = NOTES_SKILL_ROOT / "prepare.sh"
ASSEMBLE_SCRIPT = NOTES_SKILL_ROOT / "assemble.sh"
NOTES_CONFIG_PATH = NOTES_SKILL_ROOT / "config.json"
ADVANCED_DOC_PATH = NOTES_SKILL_ROOT / "ADVANCED.md"
PREPARE_STATE_FILENAMES = ("prepare_state.json",)
PREPARE_PLAN_FILENAMES = ("prepare_plan.json",)
CHUNK_BLOCK_PATTERN = re.compile(r"^chunk_([A-Za-z0-9]+)_block_\d+\.md$")
MANIFEST_PATTERN = re.compile(r"^manifest_chunk_([A-Za-z0-9]+)\.tsv$")
VTT_TIMING_RE = re.compile(
    r"(?P<start>\d{2}:\d{2}:\d{2}\.\d{3}|\d{2}:\d{2}\.\d{3})\s+-->\s+(?P<end>\d{2}:\d{2}:\d{2}\.\d{3}|\d{2}:\d{2}\.\d{3})"
)
LANGUAGE_CODE_RE = re.compile(r"\.([a-z]{2}(?:-[A-Za-z0-9]+)?)(?:-orig)?\.vtt$", re.IGNORECASE)
HTML_TAG_RE = re.compile(r"<[^>]+>")
DEFAULT_TELEGRAM_MCP_URL = "http://127.0.0.1:8799/mcp"
DEFAULT_TELEGRAM_CAPTION_TEMPLATE = ""
MARKDOWN_H1_RE = re.compile(r"^\s*#\s+(.+?)\s*$")


def advanced_setup_message(feature: str, hint: str | None = None) -> str:
    parts = [f"{feature} is part of advanced setup."]
    if hint:
        parts.append(hint.rstrip(".") + ".")
    parts.append(f"See {ADVANCED_DOC_PATH}.")
    return " ".join(parts)


def python_module_available(module_name: str) -> bool:
    return importlib.util.find_spec(module_name) is not None


def is_macos() -> bool:
    return sys.platform == "darwin"


def mlx_whisper_available() -> bool:
    """Check if mlx_whisper is available as Python module OR CLI binary."""
    return python_module_available("mlx_whisper") or shutil.which("mlx_whisper") is not None


def ensure_audio_transcription_available(feature_name: str) -> None:
    """Check that at least one transcription backend is available."""
    if os.environ.get("GROQ_API_KEY"):
        return
    if os.environ.get("ELEVENLABS_API_KEY"):
        return
    if is_macos() and (mlx_whisper_available() or parakeet_available()):
        return
    if is_macos():
        raise FileNotFoundError(
            advanced_setup_message(
                feature_name,
                "Install parakeet-mlx (`pip install parakeet-mlx`) or mlx-whisper, or set GROQ_API_KEY (free at console.groq.com)",
            )
        )
    raise FileNotFoundError(
        advanced_setup_message(
            feature_name,
            "Set GROQ_API_KEY (free at console.groq.com). MLX Whisper is macOS-only.",
        )
    )


